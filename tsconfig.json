{
  "compilerOptions": {
    "target": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "module": "ESNext",
    "rootDir": "./src",
    "baseUrl": ".",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
